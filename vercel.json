{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "node scripts/vendor-flyai.mjs && pnpm run icons && pnpm --filter @hzcd/web build",
  "installCommand": "pnpm install",
  "outputDirectory": "apps/web/dist",
  "framework": null,
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/health.ts": {
      "includeFiles": "lib/flight-search.ts"
    },
    "api/flight/search.ts": {
      "includeFiles": [
        "lib/flight-search.ts",
        "lib/flyai-bundle.cjs"
      ],
      "maxDuration": 30
    }
  }
}
